# ProspectOS — Variables de entorno
# Copia este archivo a .env.local y rellena con los valores reales.
# Los valores reales están en: https://supabase.com/dashboard/project/nbgpaylmrohdqzgaxxqh/settings/api

# Supabase — Project URL (Settings > Project URL)
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase — Anon public key (Settings > API Keys > anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key

# NOTA: Groq API key y Apify token NO van aquí.
# Van en Settings dentro de la app (/settings) para poder cambiarlas sin redeploy.
